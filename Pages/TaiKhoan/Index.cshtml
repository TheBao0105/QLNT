@page
@model QLNT.Pages_TaiKhoan.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.TaiKhoan[0].TenDangNhap)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TaiKhoan[0].MatKhau)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TaiKhoan[0].HoTen)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TaiKhoan[0].Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TaiKhoan[0].VaiTro)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TaiKhoan[0].TrangThai)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.TaiKhoan) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.TenDangNhap)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MatKhau)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.HoTen)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.VaiTro)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TrangThai)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.TaiKhoanId">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.TaiKhoanId">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.TaiKhoanId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
